filters:
  and:
    - file.folder.contains("content")
views:
  - type: table
    name: Table
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - file.tags
      - title
    sort:
      - property: file.name
        direction: DESC
      - property: file.tags
        direction: ASC
